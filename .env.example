# ── Database ────────────────────────────────────────────────────
DB_USERNAME=timetable
DB_PASSWORD=timetable123

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=mySecretKeyForJWTTokenGenerationMustBe256BitsLong!
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ── Gemini AI (optional) ────────────────────────────────────────
# Leave GEMINI_ENABLED=false to use the built-in rule-based AI (no API key needed).
# Set GEMINI_ENABLED=true and add your free API key from https://aistudio.google.com/app/apikey
# to enable the Gemini-powered AI chatbot.
GEMINI_ENABLED=false
GEMINI_API_KEY=

# ── Email Notifications (optional) ──────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
